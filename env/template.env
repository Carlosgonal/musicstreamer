# MusicStreamer runtime
MUSICSTREAMER_HOST=0.0.0.0
MUSICSTREAMER_PORT=8080
MUSICSTREAMER_SERVICE_NAME=musicstreamer
FLASK_ENV=production
FLASK_DEBUG=0

# Display / kiosk
MUSICSTREAMER_URL=http://localhost:8080
MUSICSTREAMER_KIOSK=false

# Spotify Connect placeholder
SPOTIFY_ENABLED=false
SPOTIFY_DEVICE_NAME=MusicStreamer

# Internet radio placeholder
RADIO_ENABLED=true
RADIO_DEFAULT_STATION=
MUSICSTREAMER_MPV_AUDIO_DEVICE=alsa/plughw:CARD=Headphones,DEV=0
MUSICSTREAMER_ALSA_MIXER=Headphone,Master,PCM

# Future hardware placeholders
DAC_ENABLED=false
ENCODER_ENABLED=false
BLUETOOTH_ENABLED=false
DLNA_ENABLED=false
